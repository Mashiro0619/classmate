  "privacyPolicyTitle": "Datenschutzrichtlinie",
  "@privacyPolicyTitle": {},
  "privacyPolicyEntryDesc": "Erfahren Sie, wie die App lokalen Speicher, Schulwebsite-Konfiguration, Dateiimport/-export, Webseitenanalyse und externe Links verarbeitet.",
  "@privacyPolicyEntryDesc": {},
  "privacyPolicyAcceptedVersionLabel": "Akzeptierte Version: {version}",
