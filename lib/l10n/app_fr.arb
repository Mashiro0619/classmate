  "privacyPolicyTitle": "Politique de confidentialité",
  "@privacyPolicyTitle": {},
  "privacyPolicyEntryDesc": "Découvrez comment l'application gère le stockage local, la configuration des sites scolaires, l'import/export de fichiers, l'analyse de pages web et les liens externes.",
  "@privacyPolicyEntryDesc": {},
