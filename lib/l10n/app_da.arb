  "privacyPolicyTitle": "Privatlivspolitik",
  "@privacyPolicyTitle": {},
  "privacyPolicyEntryDesc": "Lær, hvordan appen håndterer lokal lagring, konfiguration af skolens websted, import/eksport af filer, analysering af websider og eksterne links.",
  "@privacyPolicyEntryDesc": {},
