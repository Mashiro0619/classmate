  "privacyPolicyTitle": "Integritetspolicy",
  "@privacyPolicyTitle": {},
  "privacyPolicyEntryDesc": "Lär dig hur appen hanterar lokal lagring, konfiguration av skolans webbplats, import/export av filer, analys av webbsidor och externa länkar.",
  "@privacyPolicyEntryDesc": {},
  "privacyPolicyAcceptedVersionLabel": "Godkänd version: {version}",
