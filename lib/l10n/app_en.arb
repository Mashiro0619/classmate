  "privacyPolicyTitle": "Privacy Policy",
  "privacyPolicyEntryDesc": "Learn how the app handles local storage, school-site configuration, file import/export, webpage parsing, and external links.",
  "privacyPolicyAcceptedVersionLabel": "Accepted version: {version}",
  "@privacyPolicyAcceptedVersionLabel": {
    "placeholders": {
      "version": {}
    }
  },
  "privacyPolicyIntro": "Classmate is a local-first app. Timetables, timetable settings, period-time sets, and school-site configuration are stored on your device or in your browser by default. The app only reads local files, sends webpage content for parsing, opens external links, or uses system sharing when you explicitly start those actions.",
  "privacyPolicyLocalStorageTitle": "Local storage",
  "privacyPolicyLocalStorageBody": "On Android, iOS, Windows, macOS, and Linux, timetable data and related settings are stored in a local file named classmate_data.json inside the app documents directory. Editable school-site configuration is stored separately in classmate_school_sites.json. On the web, the same kinds of data are stored in browser storage. The app does not automatically upload this local data to a developer-controlled server.",
  "privacyPolicyImportExportTitle": "Import and export",
  "privacyPolicyImportExportBody": "The app reads or writes timetable JSON files, school-site JSON files, and period-template files only when you explicitly choose a file or start an export action. Importing these files is a local operation unless you also choose webpage parsing.",
  "privacyPolicySharingTitle": "Sharing",
  "privacyPolicySharingBody": "When you explicitly use sharing, the app passes the exported file to the system share sheet or to the target app you choose. How that file is handled afterward depends on the target app or service you selected.",
  "privacyPolicyExternalLinksTitle": "External links",
  "privacyPolicyExternalLinksBody": "When you open external links such as the GitHub repository, the app hands the action off to your browser or another external application. Data handling after that point is governed by the third party you open.",
  "privacyPolicyNoCollectionTitle": "What the app does not collect by default",
  "privacyPolicyNoCollectionBody": "The app does not require a Classmate account and does not enable analytics, advertising identifiers, or cloud backup by default. It also does not provide a dedicated field for collecting school account passwords. If you sign in to a school website inside the app, that interaction happens on the school page you opened.",
  "privacyPolicyFutureFeatureTitle": "Webpage parsing",
  "privacyPolicyFutureFeatureBody": "When you use school webpage import or paste HTML for parsing, the app first compresses the content locally, then sends the submitted page content, optional page title and URL, and the current app language to your configured parsing endpoint. That endpoint may forward the request to the AI service configured by the person who deployed it. The deployed backend currently limits each submitted payload to 300KB, uses its configured timeout, and allows at most 5 parsing requests per IP per day.",
  "privacyPolicyUpdatesTitle": "Policy updates",
  "privacyPolicyUpdatesBody": "The current privacy policy version is {version}. If a later version changes how data is handled, the app may ask you to read and agree to the updated policy again.",
  "@privacyPolicyUpdatesBody": {
    "placeholders": {
      "version": {}
    }
  },
  "privacyGateTitle": "Please agree to the privacy policy before using the app",
  "privacyGateSummaryStorage": "Timetables, period-time sets, and school-site configuration are stored locally by default and are not automatically uploaded to a developer server.",
  "privacyGateSummaryImportExport": "Import, export, and sharing only happen when you explicitly start them; webpage parsing sends only the compressed content you submit to your configured parsing endpoint, and you can review the parsed timetable before saving.",
  "privacyGateSummaryExternal": "Opening GitHub or other external links hands the action to your browser or another app.",
  "privacyGateSummaryUpdates": "If a later version changes how data is handled, the app may ask you to review the updated privacy policy again.",
